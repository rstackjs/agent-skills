{
  "name": "@rstackjs/agent-skills",
  "private": true,
  "scripts": {
    "build": "pnpm --parallel --filter ./packages/** build",
    "check-spell": "cspell",
    "format": "prettier -w .",
    "lint": "rslint && prettier -c . && pnpm run check-spell",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "skills-package-manager install && simple-git-hooks && pnpm build"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "devDependencies": {
    "skills-package-manager": "^0.6.2",
    "@rslint/core": "^0.4.2",
    "@rstackjs/config": "workspace:*",
    "@types/node": "^24.10.9",
    "cspell": "^9.6.4",
    "cspell-ban-words": "^0.0.4",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "pnpm": ">=10.28.2"
  }
}
